{
  "name": "svelte-repl",
  "description": "a simple REPL for Svelte which runs completely in the browser",
  "version": "0.0.2",
  "keywords": [
    "Svelte",
    "REPL",
    "offline-first",
    "browser-based"
  ],
  "author": "Andreas Rozek",
  "homepage": "https://github.com/rozek/svelte-repl#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rozek/svelte-repl.git"
  },
  "bugs": {
    "url": "https://github.com/rozek/svelte-repl/issues"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:runtime": "node build-runtime.mjs",
    "build:compiler": "node build-compiler.mjs",
    "build:assets": "npm run build:runtime && npm run build:compiler",
    "build": "npm run build:assets && vite build",
    "dev": "npm run build:assets && vite dev",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^25.3.3",
    "rollup": "^4.12.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0",
    "vite": "^5.1.0"
  },
  "dependencies": {
    "@monaco-editor/loader": "^1.4.0",
    "monaco-editor": "^0.47.0"
  }
}
